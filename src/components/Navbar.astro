---
const navItems = [
  { href: '/discovery', label: '探索', en: 'Explore' },
  { href: '/collections', label: '专辑', en: 'Collections' },
  { href: '/upload', label: '上传', en: 'Upload' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav class="fixed top-0 w-full z-50 bg-white/80 dark:bg-black/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <div class="flex items-center gap-8">
      <a class="text-2xl font-display font-bold tracking-tight" href="/">
        GLOBAL FRAME
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium tracking-wide">
        {navItems.map(item => (
          <a 
            class:list={[
              "hover:text-blue-500 dark:hover:text-blue-400 transition-colors",
              { "text-blue-500 dark:text-blue-400": currentPath === item.href || currentPath === item.href + '/' }
            ]} 
            href={item.href}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
    <div class="flex items-center gap-4">
      <button class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors">
        <span class="material-symbols-outlined">search</span>
      </button>
      <a href="/upload">
        <button class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-2.5 rounded-full text-sm font-medium transition-colors">
          加入社区
        </button>
      </a>
      <button 
        class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors"
        onclick="toggleDarkMode()"
        aria-label="Toggle dark mode"
      >
        <span class="material-symbols-outlined dark-icon hidden">dark_mode</span>
        <span class="material-symbols-outlined light-icon">light_mode</span>
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  function updateThemeIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    document.querySelectorAll('.dark-icon').forEach(el => {
      el.classList.toggle('hidden', !isDark);
    });
    document.querySelectorAll('.light-icon').forEach(el => {
      el.classList.toggle('hidden', isDark);
    });
  }
  
  // Initial update - run immediately before paint to avoid flash
  (function() {
    updateThemeIcons();
  })();
  
  // Watch for changes
  const observer = new MutationObserver(updateThemeIcons);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>
