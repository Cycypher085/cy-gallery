---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const collections = [
  { 
    id: 1,
    name: '自然风光', 
    cover: 'https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=600',
    count: 24,
    description: '山脉、湖泊、森林最美的自然瞬间'
  },
  { 
    id: 2,
    name: '城市建筑', 
    cover: 'https://images.unsplash.com/photo-1480714378408-67cf0d13bc1b?w=600',
    count: 18,
    description: '现代都市与传统建筑的完美融合'
  },
  { 
    id: 3,
    name: '极光之旅', 
    cover: 'https://images.unsplash.com/photo-1531366936337-7c912a4589a7?w=600',
    count: 12,
    description: '追逐北极光的神秘与浪漫'
  },
  { 
    id: 4,
    name: '亚洲印象', 
    cover: 'https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=600',
    count: 32,
    description: '东方文化的独特魅力'
  },
];
---

<Layout title="专辑 | Global Frame">
  <Navbar />

  <main class="pt-28 pb-24 px-6 min-h-screen bg-[#0F0F0F]">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-white mb-4">精选专辑</h1>
        <p class="text-white/60 max-w-2xl mx-auto">
          按主题分类的摄影作品集，发现不同维度的世界之美
        </p>
      </div>

      <!-- Collections Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {collections.map(collection => (
          <a href="/discovery" class="group bg-white/5 hover:bg-white/10 backdrop-blur-lg border border-white/10 hover:border-white/30 rounded-xl overflow-hidden transition-all duration-500">
            <div class="aspect-[4/3] overflow-hidden">
              <img 
                src={collection.cover} 
                alt={collection.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="p-5">
              <h3 class="text-white font-medium text-lg mb-1">{collection.name}</h3>
              <p class="text-white/50 text-sm mb-2">{collection.description}</p>
              <p class="text-blue-400 text-sm">{collection.count} 张照片</p>
            </div>
          </a>
        ))}
      </div>

      <!-- Coming Soon -->
      <div class="mt-16 text-center">
        <div class="inline-block bg-white/5 backdrop-blur-lg border border-white/10 rounded-xl px-8 py-6">
          <p class="text-white/60 mb-2">更多专辑即将上线</p>
          <p class="text-white/40 text-sm">关注我们，获取最新更新</p>
        </div>
      </div>
    </div>
  </main>
</Layout>
