---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const featuredPhotos = [
  { id: 1, location: '云南·大理', lat: 25.6065, lng: 100.2679, title: '洱海晨曦', url: 'https://images.unsplash.com/photo-1528183429752-8e2a3f8f94b9?w=800' },
  { id: 2, location: '西藏·拉萨', lat: 29.6520, lng: 91.1721, title: '布达拉宫', url: 'https://images.unsplash.com/photo-1548013146-72479768bada?w=800' },
  { id: 3, location: '冰岛·雷克雅未克', lat: 64.1466, lng: -21.9426, title: '极光之夜', url: 'https://images.unsplash.com/photo-1531366936337-7c912a4589a7?w=800' },
  { id: 4, location: '日本·京都', lat: 35.0116, lng: 135.7681, title: '竹林绿意', url: 'https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=800' },
  { id: 5, location: '挪威·特罗姆瑟', lat: 69.6496, lng: 18.9560, title: '极光探险', url: 'https://images.unsplash.com/photo-1483347756197-71ef80e95f73?w=800' },
  { id: 6, location: '新西兰·皇后镇', lat: -45.0312, lng: 168.6626, title: '湖光山色', url: 'https://images.unsplash.com/photo-1507699622108-4be3abd695ad?w=800' },
];
---

<Layout title="全球影像 | 交互式摄影地图">
  <Navbar />
  
  <!-- Hero Section with Interactive Map -->
  <section class="relative h-screen min-h-[700px] flex flex-col justify-end pt-20 overflow-hidden">
    <!-- Animated Aurora Background -->
    <div id="aurora" class="absolute inset-0 z-0 overflow-hidden pointer-events-none"></div>
    
    <!-- Stars Background -->
    <div id="stars" class="absolute inset-0 z-[1] overflow-hidden pointer-events-none"></div>
    
    <!-- Interactive Leaflet Map -->
    <div id="map" class="absolute inset-0 z-[2]" style="filter: saturate(0.5) brightness(0.4);"></div>
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 z-[3] bg-gradient-to-b from-transparent via-transparent to-[#0F0F0F]/95"></div>
    <div class="absolute inset-0 z-[3] bg-gradient-to-t from-[#0F0F0F]/50 via-transparent to-transparent"></div>
    
    <!-- Glowing Orbs -->
    <div id="orbs" class="absolute inset-0 z-[4] overflow-hidden pointer-events-none"></div>
    
    <!-- Map markers -->
    <div class="absolute inset-0 z-[25] pointer-events-none">
      {featuredPhotos.map((photo) => {
        return (
          <div 
            class="absolute w-6 h-6 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full cursor-pointer pointer-events-auto shadow-[0_0_20px_rgba(59,130,246,0.8),0_0_40px_rgba(59,130,246,0.4)] animate-pulse hover:scale-150 transition-transform duration-300"
            style={`left: ${((photo.lng + 180) / 360) * 100}%; top: ${((90 - photo.lat) / 180) * 100}%; transform: translate(-50%, -50%);`}
            data-lat={photo.lat}
            data-lng={photo.lng}
            data-title={photo.title}
            data-location={photo.location}
            data-url={photo.url}
          />
        );
      })}
    </div>

    <!-- Hero Content -->
    <div class="relative z-30 max-w-7xl mx-auto px-6 pb-32 w-full">
      <div class="bg-white/5 backdrop-blur-2xl border border-white/10 rounded-3xl p-10 max-w-3xl shadow-[0_0_60px_rgba(59,130,246,0.2)]">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"></div>
          <span class="text-blue-400 text-sm font-medium tracking-wider">交互式摄影地图</span>
        </div>
        <h1 class="text-5xl md:text-6xl font-bold mb-6 text-white leading-tight">
          用镜头<br/>捕捉世界
        </h1>
        <p class="text-lg text-white/70 mb-8 max-w-xl leading-relaxed">
          探索全球摄影师的精彩作品，在交互式地图上发现每一张照片背后的故事
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/discovery" class="group bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white px-8 py-4 rounded-full font-medium transition-all inline-flex items-center gap-3 shadow-[0_0_30px_rgba(59,130,246,0.4)] hover:shadow-[0_0_50px_rgba(59,130,246,0.6)]">
            <span class="material-symbols-outlined text-xl">explore</span>
            开始探索
            <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">arrow_forward</span>
          </a>
          <a href="/upload" class="bg-white/10 hover:bg-white/15 text-white px-8 py-4 rounded-full font-medium transition-all backdrop-blur-lg border border-white/20 inline-flex items-center gap-3 hover:border-white/30">
            <span class="material-symbols-outlined text-xl">add_photo_alternate</span>
            上传作品
          </a>
        </div>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="absolute bottom-0 left-0 right-0 z-30 bg-black/30 backdrop-blur-lg border-t border-white/10">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between text-sm">
        <div class="flex items-center gap-8">
          <div class="flex items-center gap-2 text-white/60">
            <span class="material-symbols-outlined text-blue-400">photo_library</span>
            <span><span class="text-white font-medium">2,847</span> 张照片</span>
          </div>
          <div class="flex items-center gap-2 text-white/60">
            <span class="material-symbols-outlined text-blue-400">location_on</span>
            <span><span class="text-white font-medium">128</span> 个地点</span>
          </div>
          <div class="flex items-center gap-2 text-white/60">
            <span class="material-symbols-outlined text-blue-400">person</span>
            <span><span class="text-white font-medium">364</span> 位摄影师</span>
          </div>
        </div>
        <div class="text-white/40 flex items-center gap-2">
          <span class="material-symbols-outlined text-sm animate-spin-slow">refresh</span>
          实时更新
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Photos Grid -->
  <section class="bg-[#0F0F0F] py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-3xl font-bold mb-2 text-white">精选作品</h2>
          <p class="text-white/60">来自全球摄影师的精彩瞬间</p>
        </div>
        <a href="/discovery" class="group text-blue-400 hover:text-blue-300 font-medium flex items-center gap-2 transition-colors">
          查看全部
          <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredPhotos.map((photo, i) => (
          <a href="/discovery" class="group relative bg-white/5 hover:bg-white/10 backdrop-blur-xl border border-white/10 hover:border-blue-500/50 rounded-2xl overflow-hidden transition-all duration-500 hover:shadow-[0_0_40px_rgba(59,130,246,0.2)] hover:-translate-y-1" style={`animation-delay: ${i * 100}ms`}>
            <div class="aspect-[4/3] overflow-hidden relative">
              <img 
                src={photo.url} 
                alt={photo.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-80 group-hover:opacity-60 transition-opacity" />
              
              <!-- Location Badge -->
              <div class="absolute top-4 left-4 bg-black/40 backdrop-blur-md rounded-full px-3 py-1 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-sm text-blue-400">location_on</span>
                <span class="text-white/90 text-sm">{photo.location}</span>
              </div>
            </div>
            <div class="p-5">
              <h3 class="text-white font-medium text-lg mb-1">{photo.title}</h3>
              <p class="text-white/40 text-sm flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">photo_camera</span>
                摄影师 {String.fromCharCode(65 + i)}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-black/50 backdrop-blur-sm border-t border-white/10 py-12 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-2xl font-bold text-white">GLOBAL FRAME</div>
      <div class="flex gap-8 text-sm text-white/50">
        <a href="/" class="hover:text-white transition-colors">关于我们</a>
        <a href="/" class="hover:text-white transition-colors">隐私政策</a>
        <a href="/" class="hover:text-white transition-colors">使用条款</a>
      </div>
      <p class="text-white/30 text-sm">© 2026 Global Frame. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<script>
  import L from 'leaflet';
  
  // Initialize map
  const map = L.map('map', {
    center: [20, 0],
    zoom: 2,
    minZoom: 1,
    maxZoom: 18,
    zoomControl: false,
    attributionControl: false,
    scrollWheelZoom: false,
    dragging: false,
    doubleClickZoom: false,
  });
  
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '© OpenStreetMap contributors © CARTO',
    subdomains: 'abcd',
    maxZoom: 19
  }).addTo(map);
  
  // Marker click handlers - use a closure to capture the map instance
  document.querySelectorAll('[data-lat]').forEach(marker => {
    const el = marker as HTMLElement;
    el.addEventListener('click', () => {
      const lat = parseFloat(el.dataset.lat || '0');
      const lng = parseFloat(el.dataset.lng || '0');
      map.flyTo([lat, lng], 5, { duration: 2 });
    });
  });
  
  // Aurora effect
  const aurora = document.getElementById('aurora');
  if (aurora) {
    for (let i = 0; i < 3; i++) {
      const wave = document.createElement('div');
      wave.className = 'aurora-wave';
      wave.style.cssText = `
        position: absolute;
        width: 200%;
        height: 40%;
        top: ${10 + i * 15}%;
        left: -50%;
        background: linear-gradient(90deg, 
          transparent, 
          rgba(59, 130, 246, ${0.1 + i * 0.05}), 
          rgba(147, 51, 234, ${0.1 + i * 0.05}), 
          transparent
        );
        animation: aurora ${15 + i * 5}s ease-in-out infinite;
        animation-delay: ${i * 3}s;
        transform-origin: center;
      `;
      aurora.appendChild(wave);
    }
  }
  
  // Stars
  const stars = document.getElementById('stars');
  if (stars) {
    for (let i = 0; i < 100; i++) {
      const star = document.createElement('div');
      const size = Math.random() * 2 + 1;
      star.style.cssText = `
        position: absolute;
        width: ${size}px;
        height: ${size}px;
        background: white;
        border-radius: 50%;
        left: ${Math.random() * 100}%;
        top: ${Math.random() * 60}%;
        opacity: ${Math.random() * 0.5 + 0.3};
        animation: twinkle ${3 + Math.random() * 5}s ease-in-out infinite;
        animation-delay: ${Math.random() * 5}s;
      `;
      stars.appendChild(star);
    }
  }
  
  // Glowing orbs
  const orbs = document.getElementById('orbs');
  if (orbs) {
    for (let i = 0; i < 5; i++) {
      const orb = document.createElement('div');
      orb.style.cssText = `
        position: absolute;
        width: ${100 + Math.random() * 200}px;
        height: ${100 + Math.random() * 200}px;
        background: radial-gradient(circle, rgba(59,130,246,0.15) 0%, transparent 70%);
        border-radius: 50%;
        left: ${Math.random() * 80}%;
        top: ${Math.random() * 60}%;
        animation: orbFloat ${10 + Math.random() * 10}s ease-in-out infinite;
        animation-delay: ${Math.random() * 5}s;
        pointer-events: none;
      `;
      orbs.appendChild(orb);
    }
  }
  
  // Shooting stars
  function createShootingStar() {
    const starsContainer = document.getElementById('stars');
    if (!starsContainer) return;
    
    const shootingStar = document.createElement('div');
    const startX = Math.random() * 50;
    const startY = Math.random() * 30;
    
    shootingStar.style.cssText = `
      position: absolute;
      width: 100px;
      height: 2px;
      background: linear-gradient(90deg, rgba(255,255,255,0.8), transparent);
      left: ${startX}%;
      top: ${startY}%;
      transform: rotate(-45deg);
      transform-origin: left center;
      animation: shoot 1s ease-out forwards;
      pointer-events: none;
    `;
    
    starsContainer.appendChild(shootingStar);
    setTimeout(() => shootingStar.remove(), 1000);
  }
  
  setInterval(createShootingStar, 5000);
</script>

<style is:global>
  @keyframes aurora {
    0%, 100% { transform: translateX(-20%) scaleY(1); opacity: 0.3; }
    25% { transform: translateX(0%) scaleY(1.2); opacity: 0.5; }
    50% { transform: translateX(20%) scaleY(0.8); opacity: 0.4; }
    75% { transform: translateX(10%) scaleY(1.1); opacity: 0.6; }
  }
  
  @keyframes twinkle {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }
  
  @keyframes orbFloat {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.3; }
    25% { transform: translate(30px, -30px) scale(1.1); opacity: 0.5; }
    50% { transform: translate(-20px, 20px) scale(0.9); opacity: 0.4; }
    75% { transform: translate(10px, -10px) scale(1.05); opacity: 0.5; }
  }
  
  @keyframes shoot {
    0% { opacity: 1; transform: rotate(-45deg) translateX(0); }
    100% { opacity: 0; transform: rotate(-45deg) translateX(300px); }
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0) translateX(0); opacity: 0.3; }
    25% { transform: translateY(-20px) translateX(10px); opacity: 0.6; }
    50% { transform: translateY(-10px) translateX(-10px); opacity: 0.4; }
    75% { transform: translateY(-30px) translateX(5px); opacity: 0.7; }
  }
  
  .animate-spin-slow {
    animation: spin 3s linear infinite;
  }
  
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  .leaflet-container {
    background: transparent !important;
  }
</style>
