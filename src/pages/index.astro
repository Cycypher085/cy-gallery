---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const featuredPhotos = [
  { id: 1, location: '云南·大理', lat: 25.6065, lng: 100.2679, title: '洱海晨曦', url: 'https://images.unsplash.com/photo-1528183429752-8e2a3f8f94b9?w=800' },
  { id: 2, location: '西藏·拉萨', lat: 29.6520, lng: 91.1721, title: '布达拉宫', url: 'https://images.unsplash.com/photo-1548013146-72479768bada?w=800' },
  { id: 3, location: '冰岛·雷克雅未克', lat: 64.1466, lng: -21.9426, title: '极光之夜', url: 'https://images.unsplash.com/photo-1531366936337-7c912a4589a7?w=800' },
  { id: 4, location: '日本·京都', lat: 35.0116, lng: 135.7681, title: '竹林绿意', url: 'https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=800' },
  { id: 5, location: '挪威·特罗姆瑟', lat: 69.6496, lng: 18.9560, title: '极光探险', url: 'https://images.unsplash.com/photo-1483347756197-71ef80e95f73?w=800' },
  { id: 6, location: '新西兰·皇后镇', lat: -45.0312, lng: 168.6626, title: '湖光山色', url: 'https://images.unsplash.com/photo-1507699622108-4be3abd695ad?w=800' },
];
---

<Layout title="全球影像 | 交互式摄影地图">
  <Navbar />
  
  <!-- Hero Section with Interactive Map -->
  <section class="relative h-screen min-h-[700px] flex flex-col justify-end pt-20 overflow-hidden">
    <!-- Dynamic Background Particles -->
    <div id="particles" class="absolute inset-0 z-0 overflow-hidden pointer-events-none"></div>
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 z-5 bg-gradient-to-b from-blue-900/20 via-transparent to-[#0F0F0F]/90"></div>
    
    <!-- Interactive Leaflet Map -->
    <div id="map" class="absolute inset-0 z-[1]" style="filter: saturate(0.7) brightness(0.6);"></div>
    
    <!-- Map markers (visible markers on top of map) -->
    <div class="absolute inset-0 z-20 pointer-events-none">
      {featuredPhotos.map((photo) => {
        return (
          <div 
            class="absolute w-6 h-6 bg-blue-500 rounded-full marker-pulse shadow-lg shadow-blue-500/50 cursor-pointer pointer-events-auto"
            style={`left: ${((photo.lng + 180) / 360) * 100}%; top: ${((90 - photo.lat) / 180) * 100}%; transform: translate(-50%, -50%);`}
            data-lat={photo.lat}
            data-lng={photo.lng}
            data-title={photo.title}
            data-location={photo.location}
            data-url={photo.url}
          />
        );
      })}
    </div>

    <!-- Hero Content -->
    <div class="relative z-30 max-w-7xl mx-auto px-6 pb-24 w-full">
      <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-8 max-w-2xl shadow-2xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-white drop-shadow-lg">
          用镜头捕捉世界
        </h1>
        <p class="text-lg text-white/80 mb-6 drop-shadow">
          探索全球摄影师的精彩作品，在交互式地图上发现每一张照片背后的故事
        </p>
        <div class="flex gap-4">
          <a href="/discovery" class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-full font-medium transition-all inline-flex items-center gap-2 shadow-lg shadow-blue-500/30 hover:shadow-blue-500/50">
            <span class="material-symbols-outlined">explore</span>
            开始探索
          </a>
          <a href="/upload" class="bg-white/10 hover:bg-white/20 text-white px-6 py-3 rounded-full font-medium transition-all backdrop-blur-sm border border-white/20 inline-flex items-center gap-2">
            <span class="material-symbols-outlined">add_photo_alternate</span>
            上传作品
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 text-white/60 flex flex-col items-center gap-2 animate-bounce">
      <span class="text-sm drop-shadow">向下滚动</span>
      <span class="material-symbols-outlined">keyboard_arrow_down</span>
    </div>
  </section>

  <!-- Featured Photos Grid -->
  <section class="bg-[#0F0F0F] py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-3xl font-bold mb-2 text-white">精选作品</h2>
          <p class="text-white/60">来自全球摄影师的精彩瞬间</p>
        </div>
        <a href="/discovery" class="text-blue-400 hover:text-blue-300 font-medium flex items-center gap-2 transition-colors">
          查看全部
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredPhotos.map(photo => (
          <a href={`/discovery`} class="group bg-white/5 hover:bg-white/10 backdrop-blur-lg border border-white/10 hover:border-white/30 rounded-xl overflow-hidden transition-all duration-500">
            <div class="aspect-[4/3] overflow-hidden relative">
              <img 
                src={photo.url} 
                alt={photo.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
            </div>
            <div class="p-4">
              <h3 class="text-white font-medium text-lg mb-1">{photo.title}</h3>
              <p class="text-white/50 text-sm flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">location_on</span>
                {photo.location}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-black/50 backdrop-blur-sm border-t border-white/10 py-12 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-2xl font-bold text-white">GLOBAL FRAME</div>
      <div class="flex gap-8 text-sm text-white/50">
        <a href="/" class="hover:text-white transition-colors">关于我们</a>
        <a href="/" class="hover:text-white transition-colors">隐私政策</a>
        <a href="/" class="hover:text-white transition-colors">使用条款</a>
      </div>
      <p class="text-white/30 text-sm">© 2026 Global Frame. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<script>
  import L from 'https://unpkg.com/leaflet@1.9.4/dist/leaflet-src.esm.js';
  
  // Initialize map centered on world view
  const map = L.map('map', {
    center: [20, 0],
    zoom: 2,
    minZoom: 1,
    maxZoom: 18,
    zoomControl: false,
    attributionControl: false,
    scrollWheelZoom: false,
    dragging: false,
    doubleClickZoom: false,
  });
  
  // Add dark tile layer
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '© OpenStreetMap contributors © CARTO',
    subdomains: 'abcd',
    maxZoom: 19
  }).addTo(map);
  
  // Create custom marker icon
  const markerIcon = L.divIcon({
    className: 'custom-marker',
    html: `<div class="w-4 h-4 bg-blue-500 rounded-full border-2 border-white/50 shadow-lg shadow-blue-500/50 animate-pulse"></div>`,
    iconSize: [16, 16],
    iconAnchor: [8, 8]
  });
  
  // Add click handlers to markers
  document.querySelectorAll('[data-lat]').forEach(marker => {
    const el = marker as HTMLElement;
    el.addEventListener('click', () => {
      const lat = parseFloat(el.dataset.lat || '0');
      const lng = parseFloat(el.dataset.lng || '0');
      map.flyTo([lat, lng], 6, { duration: 1.5 });
    });
  });
  
  // Particle animation
  const particlesContainer = document.getElementById('particles');
  if (particlesContainer) {
    for (let i = 0; i < 50; i++) {
      const particle = document.createElement('div');
      particle.className = 'absolute rounded-full bg-white/20';
      particle.style.cssText = `
        left: ${Math.random() * 100}%;
        top: ${Math.random() * 100}%;
        width: ${Math.random() * 4 + 1}px;
        height: ${Math.random() * 4 + 1}px;
        animation: float ${Math.random() * 10 + 10}s linear infinite;
        animation-delay: ${Math.random() * 5}s;
      `;
      particlesContainer.appendChild(particle);
    }
  }
</script>

<style is:global>
  @keyframes float {
    0%, 100% { transform: translateY(0) translateX(0); opacity: 0.3; }
    25% { transform: translateY(-20px) translateX(10px); opacity: 0.6; }
    50% { transform: translateY(-10px) translateX(-10px); opacity: 0.4; }
    75% { transform: translateY(-30px) translateX(5px); opacity: 0.7; }
  }
  
  .leaflet-container {
    background: transparent !important;
  }
  
  .custom-marker {
    background: transparent !important;
    border: none !important;
  }
</style>
